# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------- SiliconFlow ----------
SILICONFLOW_API_KEY=your_siliconflow_api_key

# ---------- 虎皮椒支付 ----------
XUNHU_APP_ID=your_xunhu_app_id
XUNHU_APP_SECRET=your_xunhu_app_secret
XUNHU_NOTIFY_URL=http://localhost:3000/api/payment/callback
XUNHU_RETURN_URL=http://localhost:3000/pricing
XUNHU_PAY_SECRET=your_xunhu_pay_secret

# ---------- 数据库初始化脚本（可选） ----------
# 仅 setup-db.js 使用，格式示例：
# postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_DB_URL=your_supabase_postgres_url
